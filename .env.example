# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Local Postgres password (see application.properties: spring.datasource.url points at
# jdbc:postgresql://localhost:5432/codesensei with username "postgres")
DB_PASSWORD=changeme

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# HS256 signing secret for JWTs — must be at least 32 bytes. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# --- Optional overrides (sensible defaults already set in application.properties) ---

# JWT_EXPIRATION_MS=7200000
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# RATE_LIMIT_CAPACITY=10
# RATE_LIMIT_REFILL_MINUTES=1

# --- Production only (see application-prod.properties, SPRING_PROFILES_ACTIVE=prod) ---

# DATABASE_URL=jdbc:postgresql://<host>:<port>/<database>
# DB_USERNAME=<prod-db-username>
# PORT=8080
